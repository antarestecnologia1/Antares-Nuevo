{
  "name": "antares-plataforma",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "postinstall": "node scripts/ensure-dev-env.mjs",
    "setup": "node scripts/ensure-dev-env.mjs",
    "setup:force": "node scripts/ensure-dev-env.mjs --force",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v",
    "db:ready": "node scripts/wait-for-postgres.mjs",
    "db:init": "node apps/api/scripts/apply-schema.mjs",
    "db:init:supabase": "node apps/api/scripts/apply-schema.mjs --supabase",
    "db:migrate": "node apps/api/scripts/apply-schema.mjs --migrations",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run start:dev -w api",
    "build:web": "npm run build -w web",
    "build:api": "npm run build -w api",
    "lint:web": "npm run lint -w web",
    "lint:portal": "eslint modules/domain",
    "test:portal-qa": "node qa/portal-regression-tests.mjs",
    "test:reports-qa": "node qa/reports-catalog-smoke.mjs && node qa/reports-bi-smoke.mjs",
    "test:qa-static": "npm run test:portal-qa && npm run test:reports-qa",
    "test:portal-e2e": "playwright test",
    "test:supabase-qa": "node qa/supabase-rest-insert-test.mjs",
    "smoke:api": "node scripts/smoke-api.mjs",
    "verify": "npm run setup && npm run build:api && npm run build:web && npm run lint:portal && npm run lint:web && npm run test:qa-static",
    "verify:e2e": "npm run test:portal-e2e",
    "verify:stack": "node scripts/run-verify-stack.mjs",
    "contracts:patch-docx": "python scripts/patch-contract-docx.py",
    "contracts:upload-r2": "node apps/api/scripts/upload-contract-templates.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "^8.57.0"
  }
}
