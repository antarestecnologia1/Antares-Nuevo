# Cloudflare Pages — qué NO subir al CDN del frontend.
# El portal estático solo necesita: index.html, app.js, styles.css, modules/, config/, imagenes empresa/, etc.
# Esto evita exponer código de la API y dejar SQL/HOWTOs en el bucket público.

# Backend NestJS (la API se expone por Cloudflare Tunnel, no por Pages).
apps/

# Scripts SQL y migraciones internas.
BD/

# Documentación interna y plantillas Word de contratos.
documentacion/
docs/
DEPLOYMENT_RUNBOOK.md
README.md
*.md

# Herramientas/QA y experimentos.
qa/
scripts/
.github/
.wrangler/
node_modules/
docker-compose.yml
package.json
package-lock.json

# Variables de entorno y secretos.
.env
.env.*

# Archivos de prueba puntuales.
test.txt
_patch_company_card.py
