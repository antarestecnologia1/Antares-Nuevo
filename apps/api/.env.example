# Copiar a `.env` en esta carpeta (`apps/api/.env`). No commitear secretos.

# --- Obligatorio: base de datos ---
# Postgres (Render internal URL, Supabase pooler, local, etc.). Debe apuntar al esquema con scripts BD/postgres/*.sql aplicados.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# --- Obligatorio: JWT (login / refresh) ---
JWT_ACCESS_SECRET=cambiar-por-cadena-larga-aleatoria-min-32-caracteres
JWT_REFRESH_SECRET=otra-cadena-larga-distinta-min-32-caracteres
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Obligatorio en producción (Render/Vercel): CORS ---
# Orígenes del navegador permitidos, separados por coma (sin espacio tras la coma salvo si forma parte del valor).
# Incluya el dominio exacto desde el que sirve el portal estático y/o Next.js (https://..., sin path).
# Si solo usa los dominios por defecto del código (transportesantares.co, app.transportesantares.co, *.vercel.app), puede dejar vacío.
CORS_ORIGINS=

# --- Opcional: Supabase Auth (si quiere duplicar usuarios en Supabase Auth además de Postgres) ---
# Sin estas variables el registro portal sigue funcionando: se genera UUID en servidor y solo se persiste en `usuarios`.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# true = usuario debe confirmar email en Supabase antes de usar Auth allí (no afecta login por API Nest si solo usa Postgres).
SUPABASE_AUTH_REQUIRE_EMAIL_CONFIRMATION=false

# --- Opcional: correo (Resend) ---
RESEND_API_KEY=
MAIL_FROM=

# Puerto local (Render inyecta PORT automáticamente).
PORT=4000
