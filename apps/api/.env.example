# --- API Nest (apps/api) — copiar a .env ---
#
# Zona horaria del proceso (logs y Date locales coherentes con Colombia)
TZ=America/Bogota

# Puerto (Render inyecta PORT)
PORT=4000

# JWT (generar valores largos aleatorios en producción)
JWT_ACCESS_SECRET=cambiar-access-secret-largo
JWT_REFRESH_SECRET=cambiar-refresh-secret-largo
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- PostgreSQL ---
#
# Opción A — Misma base Supabase donde ejecutó BD/postgres/*.sql (solo lecturas futuras vía otro cliente).
#    NO ejecute `npm run prisma:migrate` ni prisma db push sobre esa base: el modelo Prisma no coincide.
#
# Opción B — Base aparte solo para esta API demo (vacía): puede usar prisma migrate contra esa URL.
#
# Cadena con pooler Supabase (sesión corta, típica para Render; puerto 6543):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Cadena directa (SQL Editor, herramientas, algunos migrators; puerto 5432):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/antares?schema=public"

# Cola / Redis (Bull). En Render use Redis gestionado o deshabilite colas en código si no hay Redis.
REDIS_HOST=localhost
REDIS_PORT=6379

# Correo (opcional)
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev

# Supabase — misma URL que en el panel (sin /rest/v1). Service role solo en servidor (Render), nunca en el front.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT del proyecto (Settings → API → JWT) si firma tokens personalizados — no confundir con anon/service_role.
# SUPABASE_JWT_SECRET=
